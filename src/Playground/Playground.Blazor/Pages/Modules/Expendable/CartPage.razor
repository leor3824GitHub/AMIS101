@page "/expendable/cart"
@using MudBlazor
@using FSH.Playground.Blazor.ApiClient
@using Microsoft.AspNetCore.Components.Web
@inject IEmployeeClient _employeeClient
@inject ICartClient _cartClient
@inject IProductsClient _productsClient
@inject ILookupClient _lookupClient
@inject NavigationManager _navigationManager
@inject ISnackbar _snackbar

<PageTitle>Shopping Basket</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-6"></MudBreadcrumbs>

<MudContainer MaxWidth="MaxWidth.Large">
    @if (_cart != null)
    {
        <MudGrid>
            <!-- Cart Items -->
            <MudItem xs="12" md="8">
                <MudCard Class="mb-6">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h5">Shopping Basket (@_cart.Items?.Count ?? 0)</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_cart.Items != null && _cart.Items.Any())
                        {
                            <MudTable Items="_cart.Items" Hover="true" Striped="true" Dense="true">
                                <HeaderContent>
                                    <MudTh>Product</MudTh>
                                    <MudTh Align="Align.Right">Unit Price</MudTh>
                                    <MudTh Align="Align.Right">Quantity</MudTh>
                                    <MudTh Align="Align.Right">Subtotal</MudTh>
                                    <MudTh Align="Align.Right">Action</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTr>
                                        <MudTd DataLabel="Product">
                                            <MudText Typo="Typo.body2">@GetProductName(context.ProductId)</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="Unit Price" Align="Align.Right">
                                            $@context.UnitPrice.ToString("F2")
                                        </MudTd>
                                        <MudTd DataLabel="Quantity" Align="Align.Right">
                                            <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                                           Size="Size.Small"
                                                           OnClick="@(() => DecreaseQuantity(context.ProductId))" />
                                            <MudText Style="display: inline; margin: 0 8px;">@context.Quantity</MudText>
                                            <MudIconButton Icon="@Icons.Material.Filled.Add"
                                                           Size="Size.Small"
                                                           OnClick="@(() => IncreaseQuantity(context.ProductId))" />
                                        </MudTd>
                                        <MudTd DataLabel="Subtotal" Align="Align.Right">
                                            $@context.LineTotal.ToString("F2")
                                        </MudTd>
                                        <MudTd DataLabel="Action" Align="Align.Right">
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Size="Size.Small"
                                                           Color="Color.Error"
                                                           OnClick="@(() => RemoveItem(context.ProductId))" />
                                        </MudTd>
                                    </MudTr>
                                </RowTemplate>
                            </MudTable>
                            
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.DeleteSweep"
                                       OnClick="ClearCartConfirm"
                                       Class="mt-4">
                                Clear Basket
                            </MudButton>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Class="my-6">
                                Your basket is empty.
                            </MudAlert>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.ShoppingBag"
                                       OnClick="@(() => _navigationManager.NavigateTo("/expendable/shopping"))">
                                Continue Shopping
                            </MudButton>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Order Summary & Checkout -->
            <MudItem xs="12" md="4">
                <MudCard Class="sticky" Style="top: 20px;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Order Summary</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="3">
                            <MudStack Row="true" Class="justify-space-between py-2 border-bottom">
                                <MudText>Basket Items:</MudText>
                                <MudText><strong>@(_cart.Items?.Count ?? 0)</strong></MudText>
                            </MudStack>
                            <MudStack Row="true" Class="justify-space-between py-2 border-bottom">
                                <MudText>Subtotal:</MudText>
                                <MudText><strong>$@(_cart.Items?.Sum(x => x.LineTotal) ?? 0).ToString("F2")</strong></MudText>
                            </MudStack>
                            <MudStack Row="true" Class="justify-space-between py-2">
                                <MudText Typo="Typo.h6">Total:</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Primary">
                                    <strong>$@(_cart.Items?.Sum(x => x.LineTotal) ?? 0).ToString("F2")</strong>
                                </MudText>
                            </MudStack>
                        </MudStack>

                        @if (_cart.Items?.Any() == true)
                        {
                            <MudDivider Class="my-6" />

                            <MudText Typo="Typo.subtitle2" Class="mb-3">Convert to Supply Request</MudText>
                            
                            <MudSelect @bind-Value="_selectedDepartmentId"
                                       Label="Department *"
                                       AnchorOrigin="Origin.BottomCenter"
                                       Class="mb-4">
                                <MudSelectItem Value="@(Guid.Empty)">Select Department</MudSelectItem>
                                @foreach (var dept in _departmentList)
                                {
                                    <MudSelectItem Value="@dept.Id">@dept.Name</MudSelectItem>
                                }
                            </MudSelect>

                            <MudTextField @bind-Value="_businessJustification"
                                          Label="Business Justification"
                                          Lines="3"
                                          Placeholder="Why do you need these items?"
                                          Class="mb-4" />

                            <MudDatePicker @bind-Date="_neededByDate"
                                           Label="Needed By Date"
                                           DateFormat="yyyy-MM-dd"
                                           Class="mb-4" />

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       Size="Size.Large"
                                       Disabled="@(_cart.Items == null || !_cart.Items.Any() || _selectedDepartmentId == Guid.Empty)"
                                       OnClick="CheckoutAsync">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" />
                                Convert to Supply Request
                            </MudButton>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
    else
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    }
</MudContainer>

<!-- Clear Basket Confirmation Dialog -->
<MudDialog @bind-IsOpen="_showClearConfirmDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">Clear Basket?</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>Are you sure you want to clear your basket? This action cannot be undone.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showClearConfirmDialog = false)">Cancel</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="ClearCartAsync">
            Clear Basket
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private EmployeeShoppingCartDto? _cart;
    private string _currentEmployeeId = "test-employee"; // TODO: Get from authentication context
    private Guid _selectedDepartmentId = Guid.Empty;
    private string? _businessJustification = "";
    private DateTime? _neededByDate;
    private bool _showClearConfirmDialog = false;
    
    private Dictionary<Guid, string> _productNameCache = new();
    private List<DepartmentReferenceDto> _departmentList = new();
    
    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new BreadcrumbItem("Expendable", href: "/expendable"),
        new BreadcrumbItem("Shopping Basket", href: "/expendable/cart", disabled: true)
    };

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadProducts(), LoadDepartments());
        await LoadCart();
    }

    private async Task LoadProducts()
    {
        try
        {
            var result = await _productsClient.ActiveAsync(pageNumber: 1, pageSize: 1000);
            if (result.Items != null)
            {
                _productNameCache = result.Items.ToDictionary(p => p.Id, p => p.Name);
            }
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error loading product data: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadDepartments()
    {
        try
        {
            var result = await _lookupClient.DepartmentsAsync(pageNumber: 1, pageSize: 1000, isActive: true);
            if (result.Items != null)
            {
                _departmentList = result.Items.ToList();
                // Auto-select first department
                if (_departmentList.Any())
                {
                    _selectedDepartmentId = _departmentList.First().Id;
                }
            }
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error loading departments: {ex.Message}", Severity.Error);
        }
    }

    private string GetProductName(Guid productId)
    {
        return _productNameCache.TryGetValue(productId, out var name) ? name : $"Product #{productId.ToString().Substring(0, 8)}...";
    }

    private async Task LoadCart()
    {
        try
        {
            var cart = await _employeeClient.CartAsync(_currentEmployeeId);
            _cart = cart;
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error loading basket: {ex.Message}", Severity.Error);
        }
    }

    private async Task RemoveItem(Guid productId)
    {
        if (_cart == null) return;

        try
        {
            await _cartClient.ItemsDeleteAsync(_cart.Id, productId);
            await LoadCart();
            _snackbar.Add("Item removed from basket", Severity.Success);
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error removing item: {ex.Message}", Severity.Error);
        }
    }

    private async Task IncreaseQuantity(Guid productId)
    {
        if (_cart == null) return;

        try
        {
            var item = _cart.Items?.FirstOrDefault(x => x.ProductId == productId);
            if (item != null)
            {
                var command = new AddToCartCommand
                {
                    CartId = _cart.Id,
                    ProductId = productId,
                    Quantity = 1,
                    UnitPrice = item.UnitPrice
                };
                await _cartClient.ItemsPostAsync(_cart.Id, command);
                await LoadCart();
            }
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error updating quantity: {ex.Message}", Severity.Error);
        }
    }

    private async Task DecreaseQuantity(Guid productId)
    {
        if (_cart == null) return;

        try
        {
            var item = _cart.Items?.FirstOrDefault(x => x.ProductId == productId);
            if (item != null && item.Quantity > 1)
            {
                await _cartClient.ItemsDeleteAsync(_cart.Id, productId);
                var command = new AddToCartCommand
                {
                    CartId = _cart.Id,
                    ProductId = productId,
                    Quantity = item.Quantity - 1,
                    UnitPrice = item.UnitPrice
                };
                await _cartClient.ItemsPostAsync(_cart.Id, command);
                await LoadCart();
            }
            else if (item != null && item.Quantity == 1)
            {
                await RemoveItem(productId);
            }
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error updating quantity: {ex.Message}", Severity.Error);
        }
    }

    private void ClearCartConfirm()
    {
        _showClearConfirmDialog = true;
    }

    private async Task ClearCartAsync()
    {
        if (_cart == null) return;

        try
        {
            await _cartClient.ClearAsync(_cart.Id);
            await LoadCart();
            _showClearConfirmDialog = false;
            _snackbar.Add("Basket cleared", Severity.Success);
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error clearing basket: {ex.Message}", Severity.Error);
        }
    }

    private async Task CheckoutAsync()
    {
        if (_cart == null || _selectedDepartmentId == Guid.Empty)
        {
            _snackbar.Add("Please select a department", Severity.Warning);
            return;
        }

        try
        {
            var command = new ConvertCartToSupplyRequestCommand
            {
                CartId = _cart.Id,
                DepartmentId = _selectedDepartmentId.ToString(),
                BusinessJustification = _businessJustification,
                NeededByDate = _neededByDate.HasValue ? new System.DateTimeOffset(_neededByDate.Value) : null
            };

            await _cartClient.ConvertToRequestAsync(_cart.Id, command);
            _snackbar.Add("Basket converted to supply request!", Severity.Success);
            _navigationManager.NavigateTo("/expendable");
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error converting basket to supply request: {ex.Message}", Severity.Error);
        }
    }
}
