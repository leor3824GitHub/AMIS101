@page "/master-data/employees"
@using FSH.Framework.Blazor.UI.Components.Cards
@using FSH.Playground.Blazor.ApiClient
@inherits ComponentBase
@inject ISnackbar Snackbar
@inject IMaster_dataClient MasterDataClient
@inject ILookupClient LookupClient

<FshPageHeader Title="Employees" Description="Manage employee profiles">
    <ActionContent>
        <MudStack Row="true" Spacing="2" Style="width: 100%; max-width: 400px;">
            <MudTextField @bind-Value="_searchKeyword" Label="Search" Placeholder="Search employees..."
                          DebounceInterval="300" OnDebounceIntervalElapsed="@(async () => await SearchEmployees())"
                          Variant="Variant.Outlined" Size="Size.Small" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchEmployees">
                Search
            </MudButton>
        </MudStack>
    </ActionContent>
</FshPageHeader>

<div class="mt-4">
    <MudGrid Spacing="2">
        <!-- Create/Edit Form -->
        <MudItem xs="12" sm="6" md="4" Style="min-height: 100%;">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-3">@(EditingEmployee != null ? "Edit Employee" : "Create Employee")</MudText>
                    <MudStack Spacing="3">
                        <MudTextField @bind-Value="_form.EmployeeNumber" Label="Employee Number" Placeholder="Employee ID"
                                      Required="true" />
                        <MudTextField @bind-Value="_form.FirstName" Label="First Name" Placeholder="First name"
                                      Required="true" />
                        <MudTextField @bind-Value="_form.LastName" Label="Last Name" Placeholder="Last name"
                                      Required="true" />
                        <MudTextField @bind-Value="_form.WorkEmail" Label="Work Email" InputType="InputType.Email"
                                      Placeholder="work@example.com" />
                        
                        <!-- Lookups -->
                        <MudSelect @bind-Value="_form.OfficeId" Label="Office" Placeholder="Select office" Required="true">
                            @foreach (var office in _offices)
                            {
                                <MudSelectItem Value="office.Id">@office.Name</MudSelectItem>
                            }
                        </MudSelect>
                        
                        <MudSelect @bind-Value="_form.DepartmentId" Label="Department" Placeholder="Select department" Required="true">
                            @foreach (var dept in _departments)
                            {
                                <MudSelectItem Value="dept.Id">@dept.Name</MudSelectItem>
                            }
                        </MudSelect>
                        
                        <MudSelect @bind-Value="_form.PositionId" Label="Position" Placeholder="Select position" Required="true">
                            @foreach (var pos in _positions)
                            {
                                <MudSelectItem Value="pos.Id">@pos.Name</MudSelectItem>
                            }
                        </MudSelect>
                        
                        <MudCheckBox @bind-Value="_form.IsActive" Label="Active" />

                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       OnClick="SaveEmployee" Disabled="_isLoading">
                                @(EditingEmployee != null ? "Update" : "Create")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                                       OnClick="ResetForm">
                                Clear
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Employees List -->
        <MudItem xs="12" sm="6" md="8">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-3">Employees List</MudText>

                    @if (_employees.Any())
                    {
                        <MudSimpleTable Dense="true" Hover="true" Striped="true">
                            <thead>
                                <tr>
                                    <th>Employee #</th>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Office</th>
                                    <th>Department</th>
                                    <th>Position</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var employee in _employees)
                                {
                                    <tr>
                                        <td>@employee.EmployeeNumber</td>
                                        <td>@($"{employee.FirstName} {employee.LastName}")</td>
                                        <td>@(employee.WorkEmail ?? "-")</td>
                                        <td>@(GetOfficeName(employee.OfficeId))</td>
                                        <td>@(GetDepartmentName(employee.DepartmentId))</td>
                                        <td>@(GetPositionName(employee.PositionId))</td>
                                        <td><MudChip T="string" Size="Size.Small" Color="@(employee.IsActive ? Color.Success : Color.Default)">@(employee.IsActive ? "Active" : "Inactive")</MudChip></td>
                                        <td>
                                            <MudStack Row="true" Spacing="1">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                               Color="Color.Primary" OnClick="@(() => EditEmployee(employee))" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                               Color="Color.Error" OnClick="@(() => DeleteEmployee(employee.Id))" />
                                            </MudStack>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">No employees yet. Create one to get started.</MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</div>

@code {
    private EmployeeForm _form = new();
    private EmployeeReferenceDto? EditingEmployee { get; set; }
    private List<EmployeeReferenceDto> _employees = new();
    private List<OfficeReferenceDto> _offices = new();
    private List<DepartmentReferenceDto> _departments = new();
    private List<PositionReferenceDto> _positions = new();
    private bool _initialized = false;
    private bool _isLoading = false;
    private string _searchKeyword = string.Empty;

    public class EmployeeForm
    {
        public string EmployeeNumber { get; set; } = string.Empty;
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string? WorkEmail { get; set; }
        public Guid OfficeId { get; set; }
        public Guid DepartmentId { get; set; }
        public Guid PositionId { get; set; }
        public bool IsActive { get; set; } = true;
    }

    protected override async Task OnInitializedAsync()
    {
        if (_initialized) return;
        _initialized = true;
        
        // Load lookups first
        await Task.WhenAll(
            LoadOffices(),
            LoadDepartments(),
            LoadPositions()
        );
        
        await LoadEmployees();
    }

    private async Task LoadEmployees()
    {
        try
        {
            _isLoading = true;
            var response = await LookupClient.EmployeesGetAsync(pageSize: 100);
            _employees = response?.Items?.ToList() ?? new();
            StateHasChanged();
        }
        catch (HttpRequestException ex) when (
            ex.Message.Contains("StatusCode=401", StringComparison.OrdinalIgnoreCase) ||
            ex.Message.Contains("401 (Unauthorized)", StringComparison.OrdinalIgnoreCase) ||
            (ex.InnerException?.Message?.Contains("401", StringComparison.OrdinalIgnoreCase) ?? false))
        {
            Snackbar.Add("Authenticating...", Severity.Info);
            await Task.Delay(500);
            await LoadEmployeesInternal(retryCount: 1);
            return;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load employees: {ex.Message}", Severity.Error);
            _employees = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadEmployeesInternal(int retryCount = 0, int maxRetries = 3)
    {
        try
        {
            var response = await LookupClient.EmployeesGetAsync(pageSize: 100);
            _employees = response?.Items?.ToList() ?? new();
            StateHasChanged();
        }
        catch (HttpRequestException ex) when (
            (ex.Message.Contains("StatusCode=401", StringComparison.OrdinalIgnoreCase) ||
             ex.Message.Contains("401 (Unauthorized)", StringComparison.OrdinalIgnoreCase) ||
             (ex.InnerException?.Message?.Contains("401", StringComparison.OrdinalIgnoreCase) ?? false)) &&
            retryCount < maxRetries)
        {
            await Task.Delay(300 * (retryCount + 1));
            await LoadEmployeesInternal(retryCount + 1, maxRetries);
        }
        catch (Exception ex)
        {
            if (retryCount == 0)
            {
                Snackbar.Add($"Failed to load employees: {ex.Message}", Severity.Error);
            }
            _employees = new();
            StateHasChanged();
        }
    }

    private async Task LoadOffices()
    {
        try
        {
            var response = await LookupClient.OfficesAsync(pageSize: 1000, isActive: true);
            _offices = response?.Items?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load offices: {ex.Message}", Severity.Error);
            _offices = new();
        }
    }

    private async Task LoadDepartments()
    {
        try
        {
            var response = await LookupClient.DepartmentsAsync(pageSize: 1000, isActive: true);
            _departments = response?.Items?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load departments: {ex.Message}", Severity.Error);
            _departments = new();
        }
    }

    private async Task LoadPositions()
    {
        try
        {
            var response = await LookupClient.PositionsAsync(pageSize: 1000, isActive: true);
            _positions = response?.Items?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load positions: {ex.Message}", Severity.Error);
            _positions = new();
        }
    }

    private async Task SearchEmployees()
    {
        try
        {
            _isLoading = true;
            var response = await LookupClient.EmployeesGetAsync(keyword: _searchKeyword, pageSize: 100);
            var allEmployees = response?.Items?.ToList() ?? new();
            
            if (string.IsNullOrWhiteSpace(_searchKeyword))
            {
                _employees = allEmployees;
            }
            else
            {
                var searchTerm = _searchKeyword.ToLower();
                _employees = allEmployees
                    .Where(e => 
                        e.EmployeeNumber.ToLower().Contains(searchTerm) ||
                        e.FirstName.ToLower().Contains(searchTerm) ||
                        e.LastName.ToLower().Contains(searchTerm) ||
                        (e.WorkEmail?.ToLower().Contains(searchTerm) ?? false))
                    .ToList();
            }
            
            if (_employees.Count == 0 && !string.IsNullOrWhiteSpace(_searchKeyword))
            {
                Snackbar.Add("No employees found matching your search", Severity.Info);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
            _employees = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveEmployee()
    {
        if (string.IsNullOrWhiteSpace(_form.EmployeeNumber) || 
            string.IsNullOrWhiteSpace(_form.FirstName) || 
            string.IsNullOrWhiteSpace(_form.LastName) ||
            _form.OfficeId == Guid.Empty ||
            _form.DepartmentId == Guid.Empty ||
            _form.PositionId == Guid.Empty)
        {
            Snackbar.Add("All required fields must be filled", Severity.Warning);
            return;
        }

        try
        {
            if (EditingEmployee != null)
            {
                var updateCmd = new UpdateEmployeeCommand
                {
                    Id = EditingEmployee.Id,
                    EmployeeNumber = _form.EmployeeNumber,
                    FirstName = _form.FirstName,
                    LastName = _form.LastName,
                    WorkEmail = _form.WorkEmail,
                    OfficeId = _form.OfficeId,
                    DepartmentId = _form.DepartmentId,
                    PositionId = _form.PositionId,
                    IsActive = _form.IsActive
                };

                await MasterDataClient.EmployeesPutAsync(EditingEmployee.Id, updateCmd);
                Snackbar.Add("Employee updated successfully", Severity.Success);
            }
            else
            {
                var createCmd = new CreateEmployeeCommand
                {
                    EmployeeNumber = _form.EmployeeNumber,
                    FirstName = _form.FirstName,
                    LastName = _form.LastName,
                    WorkEmail = _form.WorkEmail,
                    OfficeId = _form.OfficeId,
                    DepartmentId = _form.DepartmentId,
                    PositionId = _form.PositionId,
                    IsActive = _form.IsActive
                };

                await MasterDataClient.EmployeesPostAsync(createCmd);
                Snackbar.Add("Employee created successfully", Severity.Success);
            }

            await LoadEmployees();
            ResetForm();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save employee: {ex.Message}", Severity.Error);
        }
    }

    private void EditEmployee(EmployeeReferenceDto employee)
    {
        EditingEmployee = employee;
        _form = new EmployeeForm
        {
            EmployeeNumber = employee.EmployeeNumber,
            FirstName = employee.FirstName,
            LastName = employee.LastName,
            WorkEmail = employee.WorkEmail,
            OfficeId = employee.OfficeId,
            DepartmentId = employee.DepartmentId,
            PositionId = employee.PositionId,
            IsActive = employee.IsActive
        };
        StateHasChanged();
    }

    private void ResetForm()
    {
        _form = new();
        EditingEmployee = null;
    }

    private async Task DeleteEmployee(Guid id)
    {
        try
        {
            await MasterDataClient.EmployeesDeleteAsync(id);
            await LoadEmployees();
            Snackbar.Add("Employee deleted", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete employee: {ex.Message}", Severity.Error);
        }
    }

    private string GetOfficeName(Guid officeId)
    {
        return _offices.FirstOrDefault(o => o.Id == officeId)?.Name ?? "Unknown";
    }

    private string GetDepartmentName(Guid departmentId)
    {
        return _departments.FirstOrDefault(d => d.Id == departmentId)?.Name ?? "Unknown";
    }

    private string GetPositionName(Guid positionId)
    {
        return _positions.FirstOrDefault(p => p.Id == positionId)?.Name ?? "Unknown";
    }
}
