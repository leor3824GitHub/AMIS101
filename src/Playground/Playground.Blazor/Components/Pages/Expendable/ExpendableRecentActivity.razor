@using FSH.Playground.Blazor.Services.Api.Expendable
@inject IExpendableActivityFeed ActivityFeed

<MudPaper Class="fsh-card pa-4 mt-4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
        <MudText Typo="Typo.h6">Recent Operations</MudText>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudSelect T="string" Value="_selectedCategory" ValueChanged="OnCategoryChanged" Dense="true" Label="Filter"
                       Style="min-width: 160px;">
                @foreach (var category in _categories)
                {
                    <MudSelectItem T="string" Value="@category">@category</MudSelectItem>
                }
            </MudSelect>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ClearActivity" Size="Size.Small">Clear
            </MudButton>
        </MudStack>
    </MudStack>

    @{
        var items = ActivityFeed.GetRecent(25, _selectedCategory == "All" ? null : _selectedCategory);
    }

    @if (items.Count == 0)
    {
        <MudText Typo="Typo.body2" Class="text-muted">No operations yet.</MudText>
    }
    else
    {
        <MudList T="ExpendableActivityEntry" Dense="true">
            @foreach (var item in items)
            {
                <MudListItem T="ExpendableActivityEntry">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@(item.IsSuccess? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Error)"
                                 Color="@(item.IsSuccess ? Color.Success : Color.Error)" Size="Size.Small" />
                        <MudText Typo="Typo.caption" Class="text-muted">@item.At.ToString("HH:mm:ss")</MudText>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@item.Category</MudChip>
                        <MudText Typo="Typo.body2">@item.Message</MudText>
                    </MudStack>
                </MudListItem>
            }
        </MudList>
    }
</MudPaper>

@code {
    private readonly string[] _categories = ["All", "Products", "Purchases", "Requests", "Cart", "Warehouse"];
    private string _selectedCategory = "All";

    private void ClearActivity()
    {
        ActivityFeed.Clear();
    }

    private void OnCategoryChanged(string value)
    {
        _selectedCategory = value;
    }
}