@page "/expendable/purchases"
@using FSH.Framework.Blazor.UI.Components.Cards
@using FSH.Framework.Shared.Constants
@using FSH.Modules.Expendable.Contracts
@using Microsoft.AspNetCore.Components.Authorization
@inherits ComponentBase
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthenticationStateProvider

<FshPageHeader Title="Purchase Orders" Description="Manage purchase orders">
    <ActionContent>
        @if (_canAccessPurchases)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">
                New Purchase Order
            </MudButton>
        }
    </ActionContent>
</FshPageHeader>

<div class="mt-4">
    @if (!_canAccessPurchases)
    {
        <MudAlert Severity="Severity.Warning">You do not have permission to access purchase operations.</MudAlert>
    }
    else
    {
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.body1">Purchase Orders module - API integration coming soon</MudText>
            </MudCardContent>
        </MudCard>
    }
</div>

@code {
    private bool _canAccessPurchases;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            _canAccessPurchases = false;
            return;
        }

        var roles = user.FindAll(System.Security.Claims.ClaimTypes.Role).Select(c => c.Value);
        var isAdmin = roles.Any(r => string.Equals(r, RoleConstants.Admin, StringComparison.OrdinalIgnoreCase));
        var permissions = user.FindAll(CustomClaims.Permission)
            .Select(c => c.Value)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        _canAccessPurchases = isAdmin
            || permissions.Contains(ExpendablePermissionConstants.Purchases.View)
            || permissions.Contains(ExpendablePermissionConstants.Purchases.Create)
            || permissions.Contains(ExpendablePermissionConstants.Purchases.Update)
            || permissions.Contains(ExpendablePermissionConstants.Purchases.Delete)
            || permissions.Contains(ExpendablePermissionConstants.Purchases.Approve)
            || permissions.Contains(ExpendablePermissionConstants.Purchases.Receive);
    }
}