@page "/expendable/cart"
@using FSH.Playground.Blazor.ApiClient
@using FSH.Playground.Blazor.Services.Api.Expendable
@inject IExpendableCartClient CartClient
@inject IExpendableActivityFeed ActivityFeed
@inject ISnackbar Snackbar

<FshPageHeader Title="Expendable Cart" Description="Create carts, add items, and convert to supply requests." />

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="fsh-card pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">Get / Create Cart</MudText>
            <MudTextField @bind-Value="_employeeId" Label="Employee Id" Disabled="_busy" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="GetOrCreateAsync"
                       Disabled="_busy">Get or Create</MudButton>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="fsh-card pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">Cart Item / Convert</MudText>
            <MudTextField @bind-Value="_cartId" Label="Cart Id (GUID)" Disabled="_busy" />
            <MudTextField @bind-Value="_productId" Label="Product Id (GUID)" Disabled="_busy" />
            <MudNumericField @bind-Value="_quantity" Label="Quantity" Disabled="_busy" />
            <MudNumericField @bind-Value="_unitPrice" Label="Unit Price" Disabled="_busy" />
            <MudStack Row="true" Wrap="Wrap.Wrap" Class="mt-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="AddItemAsync" Disabled="_busy">Add
                    Item</MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="GetCartAsync" Disabled="_busy">Get Cart</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="ConvertAsync" Disabled="_busy">
                        Convert</MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

<ExpendableRecentActivity />

@code {
    private const string Category = "Cart";
    private bool _busy;
    private string _employeeId = string.Empty;
    private string _cartId = string.Empty;
    private string _productId = string.Empty;
    private int _quantity = 1;
    private double _unitPrice = 1;

    private async Task GetOrCreateAsync() => await RunAsync("Get or create cart", async () =>
    {
        if (string.IsNullOrWhiteSpace(_employeeId))
        {
            Snackbar.Add("Employee Id is required", Severity.Warning);
            return;
        }

        await CartClient.GetOrCreateAsync(new GetOrCreateCartCommand
        {
            EmployeeId = _employeeId
        });
    });

    private async Task AddItemAsync() => await RunAsync("Add item to cart", async () =>
    {
        if (!TryParseGuid(_cartId, "Cart Id", out var cartId))
            return;

        if (!TryParseGuid(_productId, "Product Id", out var productId))
            return;

        if (_quantity <= 0)
        {
            Snackbar.Add("Quantity must be greater than 0", Severity.Warning);
            return;
        }

        if (_unitPrice <= 0)
        {
            Snackbar.Add("Unit Price must be greater than 0", Severity.Warning);
            return;
        }

        await CartClient.AddItemAsync(cartId, new AddToCartCommand
        {
            CartId = cartId,
            ProductId = productId,
            Quantity = _quantity,
            UnitPrice = _unitPrice
        });
    });

    private async Task GetCartAsync() => await RunAsync("Get cart", async () =>
    {
        if (!TryParseGuid(_cartId, "Cart Id", out var cartId))
            return;

        await CartClient.GetByIdAsync(cartId);
    });

    private async Task ConvertAsync() => await RunAsync("Convert cart", async () =>
    {
        if (!TryParseGuid(_cartId, "Cart Id", out var cartId))
            return;

        await CartClient.ConvertToSupplyRequestAsync(cartId, new ConvertCartToSupplyRequestCommand
        {
            CartId = cartId
        });
    });

    private bool TryParseGuid(string value, string fieldName, out Guid result)
    {
        if (Guid.TryParse(value, out result))
            return true;

        Snackbar.Add($"{fieldName} must be a valid GUID", Severity.Warning);
        return false;
    }

    private async Task RunAsync(string action, Func<Task> op) => await RunAsync(action, _ => op());

    private async Task RunAsync(string action, Func<CancellationToken, Task> op)
    {
        if (_busy) return;

        _busy = true;
        try
        {
            await op(CancellationToken.None);
            ActivityFeed.AddSuccess(Category, action);
            Snackbar.Add($"{action} succeeded", Severity.Success);
        }
        catch (ApiException ex) when (ex.StatusCode == 403)
        {
            Snackbar.Add("You don't have permission for this action", Severity.Error);
            ActivityFeed.AddFailure(Category, action, "Permission denied");
        }
        catch (ApiException ex) when (ex.StatusCode == 404)
        {
            Snackbar.Add("Resource not found", Severity.Error);
            ActivityFeed.AddFailure(Category, action, "Not found");
        }
        catch (ApiException ex) when (ex.StatusCode >= 500)
        {
            Snackbar.Add("Server error. Please contact support.", Severity.Error);
            ActivityFeed.AddFailure(Category, action, $"Server error {ex.StatusCode}");
        }
        catch (ApiException ex) when (ex.StatusCode >= 400)
        {
            Snackbar.Add($"Request error: {ex.Message}", Severity.Error);
            ActivityFeed.AddFailure(Category, action, ex.Message);
        }
        catch (HttpRequestException)
        {
            Snackbar.Add("Network error. Check your connection.", Severity.Error);
            ActivityFeed.AddFailure(Category, action, "Network error");
        }
        catch (Exception ex)
        {
            ActivityFeed.AddFailure(Category, action, ex.Message);
            Snackbar.Add($"{action} failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}